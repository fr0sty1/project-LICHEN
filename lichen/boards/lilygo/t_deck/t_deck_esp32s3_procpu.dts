/*
 * SPDX-License-Identifier: GPL-3.0-or-later
 * SPDX-FileCopyrightText: The contributors to the LICHEN project
 *
 * Lilygo T-Deck — ESP32-S3R8 (8 MB PSRAM) + SX1262 LoRa
 *
 * Pin assignments sourced from Lilygo T-Deck schematics and cross-checked
 * against the Meshtastic firmware (variants/t-deck/variant.h).
 */

/dts-v1/;

#include <espressif/esp32s3/esp32s3_r8.dtsi>
#include "t_deck-pinctrl.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/lora/sx126x.h>

/ {
	model = "Lilygo T-Deck PROCPU";
	compatible = "lilygo,t-deck";

	aliases {
		led0      = &led0;
		sw0       = &button0;
		lora0     = &lora0;
		watchdog0 = &wdt0;
	};

	chosen {
		zephyr,sram           = &sram0;
		zephyr,console        = &uart0;
		zephyr,shell-uart     = &uart0;
		zephyr,flash          = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci         = &esp32_bt_hci;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			/* T-Deck has no user LED; reuse display backlight GPIO */
			gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>; /* GPIO42 */
			label = "LCD_BL";
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			/* Boot/PRG button */
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "PRG";
			zephyr,code = <INPUT_KEY_0>;
		};
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

/*
 * SX1262 LoRa radio on SPI3.
 *   CS=GPIO9  RESET=GPIO17  BUSY=GPIO13  DIO1=GPIO45
 *   DIO2 drives the internal RF TX/RX switch (dio2-tx-enable).
 *   No TCXO — DIO3 unused.
 */
&spi3 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim3_default>;
	pinctrl-names = "default";

	lora0: lora@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		reset-gpios = <&gpio0 17 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>;
		busy-gpios  = <&gpio0 13 GPIO_ACTIVE_HIGH>;
		dio1-gpios  = <&gpio1 13 GPIO_ACTIVE_HIGH>; /* GPIO45 = gpio1[13] */
		dio2-tx-enable;
		spi-max-frequency = <16000000>;
	};
};

&timer0 { status = "okay"; };
&timer1 { status = "okay"; };
&timer2 { status = "okay"; };
&timer3 { status = "okay"; };

&wdt0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&flash0 {
	status = "okay";
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Reserve 64 kB for the bootloader */
		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 0x00010000>;
			read-only;
		};
		/* Application slot 0 (1024 kB) */
		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 0x00100000>;
		};
		/* Application slot 1 (1024 kB) — for OTA */
		slot1_partition: partition@110000 {
			label = "image-1";
			reg = <0x00110000 0x00100000>;
		};
		/* MCUboot scratch (256 kB) */
		scratch_partition: partition@210000 {
			label = "image-scratch";
			reg = <0x00210000 0x00040000>;
		};
		/* NVS / LittleFS storage */
		storage_partition: partition@250000 {
			label = "storage";
			reg = <0x00250000 0x00006000>;
		};
	};
};
