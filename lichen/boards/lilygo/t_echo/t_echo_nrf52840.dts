/*
 * SPDX-License-Identifier: GPL-3.0-or-later
 * SPDX-FileCopyrightText: The contributors to the LICHEN project
 *
 * LilyGo T-Echo V1 — nRF52840 + SX1262 + GDEW0154M10 e-ink + L76K GPS
 *
 * Pin assignments sourced from LilyGo schematics and cross-checked
 * against the Meshtastic firmware (variants/nrf52840/t-echo/variant.h).
 */

/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <zephyr/dt-bindings/lora/sx126x.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include "t_echo-pinctrl.dtsi"

/ {
	model = "LilyGo T-Echo";
	compatible = "lilygo,t-echo";

	chosen {
		zephyr,sram             = &sram0;
		zephyr,flash            = &flash0;
		zephyr,code-partition   = &slot0_partition;
	};

	/*
	 * Three indicator LEDs — all active-low.
	 * Meshtastic colour assignments: led0=green (P0.13), led1=red (P0.14),
	 * led2=blue (P0.15).  Note: colour markings in the V1 schematic and the
	 * Meshtastic source disagree slightly; treat these as best-effort.
	 */
	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 13 GPIO_ACTIVE_LOW>;
			label = "LED Green";
		};
		led1: led_1 {
			gpios = <&gpio0 14 GPIO_ACTIVE_LOW>;
			label = "LED Red";
		};
		led2: led_2 {
			gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;
			label = "LED Blue";
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio1 10 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "User button";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	aliases {
		led0      = &led0;
		led1      = &led1;
		led2      = &led2;
		sw0       = &button0;
		lora0     = &lora;
		watchdog0 = &wdt0;
	};
};

&uicr {
	gpio-as-nreset;
};

&gpiote {
	status = "okay";
};

/*
 * P0.12 enables the peripheral power rail (SX1262 + GPS + e-ink + sensor).
 * The gpio-hog asserts it high at GPIO driver init before any app code runs.
 */
&gpio0 {
	status = "okay";
	periph-pwr-hog {
		gpio-hog;
		gpios = <12 GPIO_ACTIVE_HIGH>;
		output-high;
	};
};

&gpio1 {
	status = "okay";
};

&adc {
	status = "okay";
};

/* PCF8563 real-time clock on I2C0 (SDA=P0.26, SCL=P0.27) */
&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";

	pcf8563: pcf8563@51 {
		compatible = "nxp,pcf8563";
		reg = <0x51>;
		status = "okay";
	};
};

/*
 * SX1262 LoRa radio on SPI1.
 *   CS=P0.24  RESET=P0.25  BUSY=P0.17  DIO1=P0.20
 *   DIO2 drives the internal RF TX/RX switch (dio2-tx-enable).
 *   DIO3 supplies the TCXO at 1.8 V.
 *
 * Node is left disabled here; enable via app overlay (status = "okay")
 * and set zephyr,lora = &lora0 in chosen.
 */
&spi1 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	cs-gpios = <&gpio0 24 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";

	lora: lora@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		status = "disabled";
		reset-gpios          = <&gpio0 25 GPIO_ACTIVE_LOW>;
		busy-gpios           = <&gpio0 17 GPIO_ACTIVE_HIGH>;
		dio1-gpios           = <&gpio0 20 GPIO_ACTIVE_HIGH>;
		dio2-tx-enable;
		dio3-tcxo-voltage    = <SX126X_DIO3_TCXO_1V8>;
		tcxo-power-startup-delay-ms = <5>;
		spi-max-frequency    = <8000000>;
	};
};

/*
 * GDEW0154M10 e-ink display on SPI2 — disabled by default.
 * CS=P0.30  DC=P0.28  RESET=P0.02  BUSY=P0.03  EINK_EN=P1.11
 * Enable and add display child node in an app overlay when needed.
 */
&spi2 {
	compatible = "nordic,nrf-spim";
	status = "disabled";
	cs-gpios = <&gpio0 30 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&spi2_default>;
	pinctrl-1 = <&spi2_sleep>;
	pinctrl-names = "default", "sleep";
};

/*
 * L76K GPS on UART1 (9600 baud) — disabled by default.
 * Enable in app overlay for applications that use GPS.
 */
&uart1 {
	compatible = "nordic,nrf-uarte";
	status = "disabled";
	current-speed = <9600>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-1 = <&uart1_sleep>;
	pinctrl-names = "default", "sleep";
};

/* nRF52840 native USB — available for CDC-ACM console or SLIP bridging */
zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* MCUboot bootloader (48 kB) */
		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 0x0000C000>;
		};
		/* Application slot 0 (412 kB) */
		slot0_partition: partition@c000 {
			label = "image-0";
			reg = <0x0000C000 0x00067000>;
		};
		/* Application slot 1 (412 kB) — for OTA */
		slot1_partition: partition@73000 {
			label = "image-1";
			reg = <0x00073000 0x00067000>;
		};
		/* MCUboot scratch (120 kB) */
		scratch_partition: partition@da000 {
			label = "image-scratch";
			reg = <0x000da000 0x0001e000>;
		};
		/* NVS / LittleFS storage (32 kB) */
		storage_partition: partition@f8000 {
			label = "storage";
			reg = <0x000f8000 0x00008000>;
		};
	};
};
