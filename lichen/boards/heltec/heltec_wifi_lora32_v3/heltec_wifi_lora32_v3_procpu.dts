 * SPDX-FileCopyrightText: The contributors to the LICHEN project
 *
 * Heltec WiFi LoRa 32 V3 — ESP32-S3FN8 + SX1262 + SSD1306 OLED
 *
 * Pin assignments sourced from Heltec schematics v3.0 and cross-checked
 * against the Meshtastic firmware (variants/heltec_v3/variant.h).
 */

/dts-v1/;

#include <espressif/esp32s3/esp32s3_fn8.dtsi>
#include "heltec_wifi_lora32_v3-pinctrl.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/lora/sx126x.h>

/ {
	model = "Heltec WiFi LoRa 32 V3 PROCPU";
	compatible = "heltec,wifi-lora32-v3";

	aliases {
		led0      = &led0;
		sw0       = &button0;
		lora0     = &lora0;
		watchdog0 = &wdt0;
	};

	chosen {
		zephyr,sram           = &sram0;
		zephyr,console        = &uart0;
		zephyr,shell-uart     = &uart0;
		zephyr,flash          = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci         = &esp32_bt_hci;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
			label = "LED";
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "PRG";
			zephyr,code = <INPUT_KEY_0>;
		};
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

/*
 * SSD1306 OLED on I2C0 — disabled by default.
 * Enable via app overlay for applications that use the display.
 */
&i2c0 {
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";
	status = "disabled";

	ssd1306: ssd1306@3c {
		compatible = "solomon,ssd1306fb";
		reg = <0x3c>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		segment-remap;
		com-invdir;
		prechargep = <0x22>;
		status = "disabled";
	};
};

/*
 * SX1262 LoRa radio on SPI2.
 *   CS=GPIO8  RESET=GPIO12  BUSY=GPIO13  DIO1=GPIO14
 *   DIO2 drives the internal RF TX/RX switch (dio2-tx-enable).
 *   DIO3 supplies the TCXO at 1.8 V.
 */
&spi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";

	lora0: lora@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		reset-gpios          = <&gpio0 12 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>;
		busy-gpios           = <&gpio0 13 GPIO_ACTIVE_HIGH>;
		dio1-gpios           = <&gpio0 14 GPIO_ACTIVE_HIGH>;
		dio2-tx-enable;
		dio3-tcxo-voltage    = <SX126X_DIO3_TCXO_1V8>;
		tcxo-power-startup-delay-ms = <5>;
		spi-max-frequency    = <16000000>;
	};
};

&timer0 { status = "okay"; };
&timer1 { status = "okay"; };
&timer2 { status = "okay"; };
&timer3 { status = "okay"; };

&wdt0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&flash0 {
	status = "okay";
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Reserve 64 kB for the bootloader */
		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 0x00010000>;
			read-only;
		};
		/* Application slot 0 (1024 kB) */
		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 0x00100000>;
		};
		/* Application slot 1 (1024 kB) — for OTA */
		slot1_partition: partition@110000 {
			label = "image-1";
			reg = <0x00110000 0x00100000>;
		};
		/* MCUboot scratch (256 kB) */
		scratch_partition: partition@210000 {
			label = "image-scratch";
			reg = <0x00210000 0x00040000>;
		};
		/* NVS / LittleFS storage */
		storage_partition: partition@250000 {
			label = "storage";
			reg = <0x00250000 0x00006000>;
		};
	};
};
